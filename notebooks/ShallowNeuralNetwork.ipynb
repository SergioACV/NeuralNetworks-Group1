    "# =============================================================================\n",
    "# METRICS — Full evaluation of the shallow model on the held-out test set\n",
    "# =============================================================================\n",
    "\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.gridspec as gridspec\n",
    "from sklearn.metrics import roc_curve, auc as sk_auc\n",
    "from sklearn.calibration import calibration_curve\n",
    "\n",
    "# ── Guard ────────────────────────────────────────────────────────────────────\n",
    "for _var in (\"shallow_model\", \"X_test\", \"y_test\", \"best_threshold\", \"history_shallow\"):\n",
    "    if _var not in globals():\n",
    "        raise ValueError(f\"'{_var}' not found. Run the Training cell first.\")\n",
    "\n",
    "# ── Predictions ──────────────────────────────────────────────────────────────\n",
    "y_prob  = shallow_model.predict(X_test, verbose=0).reshape(-1)\n",
    "y_true  = y_test.astype(np.int32)\n",
    "y_pred  = (y_prob >= best_threshold).astype(np.int32)\n",
    "\n",
    "# ── Confusion matrix values ───────────────────────────────────────────────────\n",
    "tp = int(np.sum((y_pred == 1) & (y_true == 1)))\n",
    "tn = int(np.sum((y_pred == 0) & (y_true == 0)))\n",
    "fp = int(np.sum((y_pred == 1) & (y_true == 0)))\n",
    "fn = int(np.sum((y_pred == 0) & (y_true == 1)))\n",
    "\n",
    "precision = tp / (tp + fp) if (tp + fp) > 0 else 0.0\n",
    "recall    = tp / (tp + fn) if (tp + fn) > 0 else 0.0\n",
    "f1        = (2 * precision * recall / (precision + recall)\n",
    "             if (precision + recall) > 0 else 0.0)\n",
    "accuracy  = (tp + tn) / (tp + tn + fp + fn)\n",
    "specificity = tn / (tn + fp) if (tn + fp) > 0 else 0.0\n",
    "\n",
    "auc_m = keras.metrics.AUC()\n",
    "auc_m.update_state(y_true, y_prob)\n",
    "roc_auc = float(auc_m.result().numpy())\n",
    "\n",
    "# ── ROC curve data ────────────────────────────────────────────────────────────\n",
    "fpr, tpr, _ = roc_curve(y_true, y_prob)\n",
    "\n",
    "# ── Calibration curve data ────────────────────────────────────────────────────\n",
    "frac_pos, mean_pred = calibration_curve(y_true, y_prob, n_bins=15, strategy=\"quantile\")\n",
    "\n",
    "# ── Training history ──────────────────────────────────────────────────────────\n",
    "hist        = pd.DataFrame(history_shallow.history)\n",
    "hist.index  = np.arange(1, len(hist) + 1)\n",
    "epochs_ran  = len(hist)\n",
    "best_epoch  = int(hist[\"val_auc\"].idxmax())\n",
    "\n",
    "# =============================================================================\n",
    "# PLOT — 2×2 dashboard\n",
    "# =============================================================================\n",
    "\n",
    "fig = plt.figure(figsize=(14, 10))\n",
    "fig.suptitle(\"Shallow Network — Evaluation Dashboard (Test Set)\", fontsize=14, fontweight=\"bold\", y=1.01)\n",
    "gs  = gridspec.GridSpec(2, 2, hspace=0.38, wspace=0.32)\n",
    "\n",
    "# ── 1. Loss curves ────────────────────────────────────────────────────────────\n",
    "ax1 = fig.add_subplot(gs[0, 0])\n",
    "ax1.plot(hist.index, hist[\"loss\"],     label=\"Train\",      linewidth=2)\n",
    "ax1.plot(hist.index, hist[\"val_loss\"], label=\"Validation\", linewidth=2)\n",
    "ax1.axvline(best_epoch, color=\"crimson\", linestyle=\"--\", linewidth=1.4,\n",
    "            label=f\"Best epoch ({best_epoch})\")\n",
    "ax1.set_title(\"Loss per Epoch\")\n",
    "ax1.set_xlabel(\"Epoch\")\n",
    "ax1.set_ylabel(\"Binary Crossentropy\")\n",
    "ax1.legend(fontsize=8)\n",
    "ax1.grid(alpha=0.25)\n",
    "\n",
    "# ── 2. AUC curves ─────────────────────────────────────────────────────────────\n",
    "ax2 = fig.add_subplot(gs[0, 1])\n",
    "ax2.plot(hist.index, hist[\"auc\"],     label=\"Train\",      linewidth=2)\n",
    "ax2.plot(hist.index, hist[\"val_auc\"], label=\"Validation\", linewidth=2)\n",
    "ax2.axvline(best_epoch, color=\"crimson\", linestyle=\"--\", linewidth=1.4,\n",
    "            label=f\"Best epoch ({best_epoch})\")\n",
    "ax2.set_title(\"AUC per Epoch\")\n",
    "ax2.set_xlabel(\"Epoch\")\n",
    "ax2.set_ylabel(\"ROC AUC\")\n",
    "ax2.legend(fontsize=8)\n",
    "ax2.grid(alpha=0.25)\n",
    "\n",
    "# ── 3. ROC curve ─────────────────────────────────────────────────────────────\n",
    "ax3 = fig.add_subplot(gs[1, 0])\n",
    "ax3.plot(fpr, tpr, linewidth=2, label=f\"AUC = {roc_auc:.4f}\")\n",
    "ax3.plot([0, 1], [0, 1], \"k--\", linewidth=1, label=\"Random (0.5000)\")\n",
    "ax3.set_title(\"ROC Curve — Test Set\")\n",
    "ax3.set_xlabel(\"False Positive Rate\")\n",
    "ax3.set_ylabel(\"True Positive Rate\")\n",
    "ax3.legend(fontsize=9)\n",
    "ax3.grid(alpha=0.25)\n",
    "\n",
    "# ── 4. Calibration curve ──────────────────────────────────────────────────────\n",
    "ax4 = fig.add_subplot(gs[1, 1])\n",
    "ax4.plot(mean_pred, frac_pos, \"s-\", linewidth=2, label=\"Model\")\n",
    "ax4.plot([0, 1], [0, 1], \"k--\", linewidth=1, label=\"Perfect calibration\")\n",
    "ax4.set_title(\"Calibration Curve — Test Set\")\n",
    "ax4.set_xlabel(\"Mean Predicted Probability\")\n",
    "ax4.set_ylabel(\"Fraction of Positives\")\n",
    "ax4.legend(fontsize=9)\n",
    "ax4.grid(alpha=0.25)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# =============================================================================\n",
    "# PRINTED SUMMARY\n",
    "# =============================================================================\n",
    "\n",
    "cm_grid = np.array([[tn, fp], [fn, tp]])\n",
    "\n",
    "print(\"\\n\" + \"=\"*56)\n",
    "print(\"  SHALLOW MODEL — FINAL TEST SET METRICS\")\n",
    "print(\"=\"*56)\n",
    "print(f\"  Threshold (val F1-optimal) : {best_threshold:.4f}\")\n",
    "print(f\"  Epochs trained             : {epochs_ran}  (best: {best_epoch})\")\n",
    "print(\"-\"*56)\n",
    "print(f\"  AUC (ROC)                  : {roc_auc:.4f}\")\n",
    "print(f\"  Accuracy                   : {accuracy:.4f}\")\n",
    "print(f\"  Precision                  : {precision:.4f}\")\n",
    "print(f\"  Recall (Sensitivity)       : {recall:.4f}\")\n",
    "print(f\"  Specificity                : {specificity:.4f}\")\n",
    "print(f\"  F1 Score                   : {f1:.4f}\")\n",
    "print(\"-\"*56)\n",
    "print(\"  Confusion Matrix\")\n",
    "print(f\"                Pred 0   Pred 1\")\n",
    "print(f\"  Actual 0    {tn:>8,} {fp:>8,}   (TN / FP)\")\n",
    "print(f\"  Actual 1    {fn:>8,} {tp:>8,}   (FN / TP)\")\n",
    "print(\"=\"*56)\n",
    "\n",
    "# ── Diagnostic warnings ───────────────────────────────────────────────────────\n",
    "if roc_auc < 0.52:\n",
    "    print(\"\\n⚠️  WARNING: AUC < 0.52 — model is barely above random.\")\n",
    "    print(\"   Consider: more expressive features, longer lookback windows,\")\n",
    "    print(\"   or cross-sectional normalization of returns per date.\")\n",
    "\n",
    "if recall > 0.98 and precision < 0.55:\n",
    "    print(\"\\n⚠️  WARNING: Recall ≈ 1.0 with low precision — model is predicting\")\n",
    "    print(\"   almost everything as positive. Lower the threshold or\")\n",
    "    print(\"   re-examine class balance.\")\n",
    "\n",
    "if abs(precision - recall) > 0.25:\n",
    "    print(\"\\n⚠️  Precision/Recall imbalance detected.\")\n",
    "    print(\"   Consider optimising threshold for precision-recall balance (F1)\")\n",
    "    print(\"   or using a business-specific objective (e.g. maximize precision\")\n",
    "    print(\"   subject to recall >= 0.40).\")"
