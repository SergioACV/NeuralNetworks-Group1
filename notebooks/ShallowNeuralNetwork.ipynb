    "thresholds  = np.linspace(0.01, 0.99, 500)\n",
    "pred_mat    = y_prob_shallow[:, None] >= thresholds[None, :]\n",
    "y_col       = y_true_shallow[:, None].astype(bool)\n",
    "\n",
    "tp_v = np.sum( pred_mat &  y_col, axis=0, dtype=np.int64).astype(np.float64)\n",
    "fp_v = np.sum( pred_mat & ~y_col, axis=0, dtype=np.int64).astype(np.float64)\n",
    "fn_v = np.sum(~pred_mat &  y_col, axis=0, dtype=np.int64).astype(np.float64)\n",
    "\n",
    "prec_v = np.divide(tp_v, tp_v + fp_v, out=np.zeros_like(tp_v), where=(tp_v + fp_v) > 0)\n",
    "rec_v  = np.divide(tp_v, tp_v + fn_v, out=np.zeros_like(tp_v), where=(tp_v + fn_v) > 0)\n",
    "f1_num = 2.0 * prec_v * rec_v\n",
    "f1_den = prec_v + rec_v\n",
    "f1_v   = np.divide(f1_num, f1_den, out=np.zeros_like(f1_num), where=f1_den > 0)\n",
    "\n",
    "best_idx       = int(np.argmax(f1_v))\n",
    "best_threshold = float(thresholds[best_idx])\n",
    "best_precision = float(prec_v[best_idx])\n",
    "best_recall    = float(rec_v[best_idx])\n",
    "best_f1        = float(f1_v[best_idx])\n",
    "y_pred_shallow = (y_prob_shallow >= best_threshold).astype(np.int32)\n",
