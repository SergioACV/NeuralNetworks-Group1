    "def build_research_dataset_from_df(input_df):\n",
    "    required_cols = {\"date\", \"open\", \"high\", \"low\", \"close\", \"volume\", \"Name\", \"adjusted_price\", \"return_1d\"}\n",
    "    missing = required_cols.difference(input_df.columns)\n",
    "    if missing:\n",
    "        raise ValueError(f\"Dataset missing columns: {sorted(missing)}\")\n",
    "\n",
    "    work = input_df.copy()\n",
    "    work[\"date\"] = pd.to_datetime(work[\"date\"], errors=\"coerce\")\n",
    "    work = work.dropna(subset=[\"date\", \"Name\"]).sort_values([\"Name\", \"date\"]).reset_index(drop=True)\n",
    "\n",
    "    eps = 1e-6\n",
    "    g   = work.groupby(\"Name\", group_keys=False)\n",
    "\n",
    "    work[\"intraday_return\"]    = (work[\"close\"] - work[\"open\"])  / np.maximum(np.abs(work[\"open\"]),  eps)\n",
    "    work[\"high_low_range\"]     = (work[\"high\"]  - work[\"low\"])   / np.maximum(np.abs(work[\"close\"]), eps)\n",
    "    work[\"close_to_high\"]      = (work[\"high\"]  - work[\"close\"]) / np.maximum(np.abs(work[\"close\"]), eps)\n",
    "    work[\"close_to_low\"]       = (work[\"close\"] - work[\"low\"])   / np.maximum(np.abs(work[\"close\"]), eps)\n",
    "    work[\"open_to_high\"]       = (work[\"high\"]  - work[\"open\"])  / np.maximum(np.abs(work[\"open\"]),  eps)\n",
    "    work[\"open_to_low\"]        = (work[\"open\"]  - work[\"low\"])   / np.maximum(np.abs(work[\"open\"]),  eps)\n",
    "    work[\"log_volume\"]         = np.log1p(np.clip(work[\"volume\"], 0.0, None))\n",
    "    work[\"adjusted_close_gap\"] = (work[\"adjusted_price\"] - work[\"close\"]) / np.maximum(np.abs(work[\"close\"]), eps)\n",
    "\n",
    "    for lag in [1, 2, 3, 5, 10]:\n",
    "        work[f\"return_lag_{lag}\"] = g[\"return_1d\"].shift(lag)\n",
    "    for lag in [1, 2, 3]:\n",
    "        work[f\"volume_change_lag_{lag}\"] = g[\"volume\"].shift(lag).pct_change().replace([np.inf, -np.inf], np.nan)\n",
    "    for w in [3, 5, 10]:\n",
    "        work[f\"return_mean_{w}\"]   = g[\"return_1d\"].transform(lambda s: s.rolling(w).mean())\n",
    "        work[f\"return_std_{w}\"]    = g[\"return_1d\"].transform(lambda s: s.rolling(w).std())\n",
    "        vol_mean                   = g[\"volume\"].transform(lambda s: s.rolling(w).mean())\n",
    "        work[f\"volume_vs_mean_{w}\"] = work[\"volume\"] / np.maximum(vol_mean, eps) - 1.0\n",
    "    for h in [2, 3, 5, 10, 20]:\n",
    "        work[f\"adj_momentum_{h}\"] = g[\"adjusted_price\"].pct_change(h).replace([np.inf, -np.inf], np.nan)\n",
    "\n",
    "    work[\"future_return_1d\"] = g[\"adjusted_price\"].pct_change().shift(-1)\n",
    "    work[\"target_bin\"]       = (work[\"future_return_1d\"] > 0).astype(np.float32)\n",
    "\n",
    "    feature_cols = [\n",
    "        \"return_1d\", \"intraday_return\", \"high_low_range\", \"close_to_high\", \"close_to_low\",\n",
    "        \"open_to_high\", \"open_to_low\", \"log_volume\", \"adjusted_close_gap\",\n",
    "        \"return_lag_1\", \"return_lag_2\", \"return_lag_3\", \"return_lag_5\", \"return_lag_10\",\n",
    "        \"volume_change_lag_1\", \"volume_change_lag_2\", \"volume_change_lag_3\",\n",
    "        \"return_mean_3\", \"return_mean_5\", \"return_mean_10\",\n",
    "        \"return_std_3\",  \"return_std_5\",  \"return_std_10\",\n",
    "        \"volume_vs_mean_3\", \"volume_vs_mean_5\", \"volume_vs_mean_10\",\n",
    "        \"adj_momentum_2\", \"adj_momentum_3\", \"adj_momentum_5\", \"adj_momentum_10\", \"adj_momentum_20\",\n",
    "    ]\n",
    "    model_df = work.dropna(subset=feature_cols + [\"target_bin\"]).copy()\n",
    "    if model_df.empty:\n",
    "        raise ValueError(\"Feature engineering produced an empty dataset.\")\n",
    "    return (\n",
    "        model_df[feature_cols].to_numpy(dtype=np.float32),\n",
    "        model_df[\"target_bin\"].to_numpy(dtype=np.float32),\n",
    "        model_df[\"date\"].to_numpy(),\n",
    "        feature_cols,\n",
    "    )\n",
    "\n",
